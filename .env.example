# ============================================================================
# THE SOVEREIGN COMMANDER: Environment Configuration
# ============================================================================

# ZMQ Configuration
ZMQ_ENDPOINT=tcp://127.0.0.1:5555
ZMQ_HEARTBEAT_INTERVAL=2
ZMQ_HEARTBEAT_TIMEOUT=5

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_POOL_SIZE=50

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sovereign_commander
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_POOL_SIZE=20

# Cold Dump Configuration
COLD_DUMP_INTERVAL_MINUTES=5
COLD_DUMP_BATCH_SIZE=1000

# Auth Vault Configuration
AUTH_VAULT_KEY_ROTATION_HOURS=24
AUTH_VAULT_TOKEN_TTL_MINUTES=15
AUTH_VAULT_SECRET_PATH=/opt/sovereign/secrets

# LLM Configuration
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-opus

# QA Configuration
QA_STATIC_ANALYSIS_TIMEOUT=30
QA_LLM_REVIEW_TIMEOUT=120
QA_REJECTION_RATE_TARGET=0.90

# Monitoring & Logging
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090
ENABLE_TELEMETRY=true

# Security
ENABLE_TLS=true
TLS_CERT_PATH=/opt/sovereign/certs/server.crt
TLS_KEY_PATH=/opt/sovereign/certs/server.key

# Development
DEBUG_MODE=false
ENABLE_PROFILING=false
